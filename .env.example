# X AUTOMATION BOT - ENVIRONMENT CONFIGURATION
# ================================================
# SETUP: Copy this file to .env and fill in your values
# SECURITY: NEVER commit .env to git (add to .gitignore)

# ========== API KEYS (Required) ==========
# Get from: https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ========== DEBUG & LOGGING ==========
# Debug mode (verbose logging)
DEBUG=false
LOG_LEVEL=INFO

# ========== SEARCH & ENGAGEMENT STRATEGY ==========
# Search keywords (comma-separated, randomly selected each cycle)
SEARCH_KEYWORDS=AI,python,automation,typescript,web development,startup,entrepreneurship

# Engagement probabilities (0.0-1.0, what % chance to do each action)
LIKE_PROBABILITY=0.6           # 60% chance to like matching tweets
REPLY_PROBABILITY=0.25         # 25% chance to reply (if quality is good)
FOLLOW_PROBABILITY=0.15        # 15% chance to follow author

# Minimum engagement score to interact with tweet
# (tweets below this score are skipped to avoid low-quality content)
MIN_ENGAGEMENT_SCORE=5

# ========== RATE LIMITS - DAILY (prevent detection) ==========
# X detects bots by sudden action spikes. Spread actions throughout day.
# These are HARD LIMITS - actions blocked once reached
MAX_LIKES_PER_DAY=20
MAX_REPLIES_PER_DAY=5
MAX_FOLLOWS_PER_DAY=10
MAX_POSTS_PER_DAY=2

# ========== RATE LIMITS - HOURLY (distributed) ==========
# Prevents clustering (5 actions in 2 mins = instant ban)
MAX_LIKES_PER_HOUR=3
MAX_REPLIES_PER_HOUR=1
MAX_FOLLOWS_PER_HOUR=2

# ========== BROWSER SETTINGS ==========
# Run in headless mode (no visible window - faster, less resource)
HEADLESS_MODE=true

# Enable stealth mode (hide automation indicators from X)
STEALTH_MODE=true

# Browser timeout in milliseconds (30s = reasonable for slow networks)
BROWSER_TIMEOUT_MS=30000

# ========== AI CONTENT GENERATION ==========
# Which Claude model to use
# Fast & cheap: claude-3-haiku-20240307 (recommended)
# Balanced:     claude-3-5-sonnet-20241022
# Best quality: claude-opus-4-1 (more expensive)
AI_MODEL=claude-3-haiku-20240307

# Max tokens for reply generation (100 = ~75 chars, good for tweets)
AI_MAX_TOKENS=100

# Quality threshold (7.5 = B grade, only retry if below this)
# Higher = more retries = more expensive, slower
# Lower = faster, cheaper, could be low quality
AI_QUALITY_THRESHOLD=7.5

# Max retry attempts for improving content quality
AI_MAX_RETRIES=3

# ========== HUMAN BEHAVIOR SIMULATION ==========
# Typing speed in words per minute (simulates human behavior)
# Average human: 60 WPM
# Conservative: 40 WPM (slower, more human)
# Fast: 80 WPM
TYPING_WPM=60

# Delay between actions (prevent patterns)
MIN_ACTION_DELAY_MS=2000      # Min 2 seconds between actions
MAX_ACTION_DELAY_MS=8000      # Max 8 seconds between actions

# Pause (simulating reading) between interaction cycles
MIN_PAUSE_SECONDS=2
MAX_PAUSE_SECONDS=8

# Minutes between engagement cycles (varies by ±20%)
CYCLE_INTERVAL_MINUTES=90

# Add randomness to ALL timings (STRONGLY RECOMMENDED)
ADD_TIMING_VARIATION=true

# ========== LANGUAGE SETTINGS ==========
# Languages to reply to (comma-separated language codes)
SUPPORTED_LANGUAGES=en

# Auto-translate non-English (false = skip them)
AUTO_TRANSLATE=false

# Language detection confidence (0.7 = 70% confidence required)
LANGUAGE_MIN_CONFIDENCE=0.7

# ========== DATABASE & STORAGE ==========
# SQLite database paths (relative to project root)
DATABASE_PATH=data/bot.db
RATE_LIMITER_DB=data/rate_limiter.db

# Data retention (delete old logs to save space)
ENGAGEMENT_LOG_RETENTION_DAYS=90
ERROR_LOG_RETENTION_DAYS=180

# ========== MONITORING & DEBUGGING ==========
# Export metrics (likes, replies, errors) for monitoring
EXPORT_METRICS=true
METRICS_FILE=data/metrics.json

# Log ALL actions to database (for analytics)
LOG_TO_DATABASE=true

# Save screenshots when errors occur (helps debugging, uses disk space)
SAVE_ERROR_SCREENSHOTS=false

# ========== ERROR RECOVERY ==========
# Max consecutive errors before pausing bot
MAX_CONSECUTIVE_ERRORS=5

# Hours to pause if X detects bot behavior
DETECTION_COOLDOWN_HOURS=24

# ========== DEPLOYMENT SETTINGS ==========
# Environment name (affects logging, error handling)
# development / staging / production
ENVIRONMENT=development

# Monitoring API port (if monitoring enabled)
MONITORING_PORT=8000

# ========== SESSION MANAGEMENT ==========
# Session file location (stores X authentication cookies)
SESSION_FILE=session.json

# Auto-refresh expired sessions
AUTO_REFRESH_SESSION=true

# Refresh interval (hours) - helps maintain session validity
SESSION_REFRESH_HOURS=24

# ========== OPTIONAL: ADVANCED FEATURES (future) ==========
# Slack webhook for alerts (optional - get from Slack admin)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Database backup (optional)
# AUTO_BACKUP_DATABASE=false
# BACKUP_INTERVAL_HOURS=24

